# Textboard Environment Variables
# Copy this file to .env and adjust the values

# Server port (default: 3000)
PORT=3000

# Node environment (production/development)
NODE_ENV=production

# SQLite database path
# For Docker: /app/data/textboard.db
# For local: ./textboard.db or ./data/textboard.db
DB_PATH=./data/textboard.db
